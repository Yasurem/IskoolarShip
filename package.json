{
  "name": "iskoolarship",
  "version": "0.1.0",
  "private": true,
  "description": "IskoolarShip scholarship match finding Android app monorepo.",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm --workspace @iskoolarship/mobile run start",
    "dev:api": "npm --workspace @iskoolarship/api run dev",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}

{
  "name": "@iskoolarship/algorithms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "npm --workspace @iskoolarship/types run build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "npm --workspace @iskoolarship/types run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@iskoolarship/types": "0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}

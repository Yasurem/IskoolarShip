<script>
        // Micro-interactions and simple state handling
        document.querySelectorAll('.filter-chip').forEach(chip => {
            chip.addEventListener('click', function() {
                document.querySelectorAll('.filter-chip').forEach(c => {
                    c.classList.remove('bg-primary', 'text-on-primary', 'shadow-md');
                    c.classList.add('bg-surface-container', 'text-on-surface-variant');
                });
                this.classList.remove('bg-surface-container', 'text-on-surface-variant');
                this.classList.add('bg-primary', 'text-on-primary', 'shadow-md');
            });
        });

        // Simple function to toggle empty state for demo purposes
        function toggleEmptyState(isEmpty) {
            const list = document.querySelector('.grid');
            const empty = document.getElementById('empty-state');
            if (isEmpty) {
                list.classList.add('hidden');
                empty.classList.remove('hidden');
            } else {
                list.classList.remove('hidden');
                empty.classList.add('hidden');
            }
        }
    </script>
